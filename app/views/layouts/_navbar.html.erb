<nav class="navbar navbar-expand-lg navbar-light bg-success p-2">
  <a class="navbar-brand text-light" href="<%= home_index_path %>">
    <% if user_signed_in? %>
      <%= current_user.first_name %> <%= current_user.last_name %> 
    <% end %>
  </a>
  <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
    <span class="navbar-toggler-icon"></span>
  </button>
  <div class="collapse navbar-collapse" id="navbarNav">
    <ul class="navbar-nav">
      <li class="nav-item  active">
        <%= link_to 'Home', home_index_path, class: 'nav-link text-light' %>
      </li>
      <li class="nav-item ">
        <%= link_to 'Posts', posts_path, class: 'nav-link text-light' %>
      </li>
      <li class="nav-item ">
        <%= link_to 'Users', users_path, class: 'nav-link text-light' %>
      </li>
      <li class="nav-item ">
        <%= link_to 'Calendar', calendar_index_path, class: 'nav-link text-light' %>
      </li>
      <li class="nav-item ">
        <% if user_signed_in? %>
            <div class="d-flex justify-content-end">
              <%= button_to destroy_user_session_path, method: :delete, class: "btn btn-none text-decoration-none text-light mb-2 d-flex align-items-center gap-2" do %>
                <i class="fas fa-sign-out-alt"></i>
                Logout
              <% end %>
            </div>
        <% else %>
          <%= link_to 'Sign In', new_user_session_path, class: 'nav-link text-light' %>
          <%= link_to 'Sign Up', new_user_registration_path, class: 'nav-link text-light' %>
        <% end %>
      </li>
    </ul>
  </div>
</nav>

