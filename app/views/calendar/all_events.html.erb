
<%= render 'layouts/navbar' %>
<div class="container-fluid  p-5 rounded" style=" background-color: rgba(255, 255, 0, 0.292);">
  <div class="col-7 m-auto ">
    <div class="text-center mb-4">
      <% if params[:date].present? && params[:month_only] %>
        <h3 class="text-success">Events of <%= @first_day.strftime("%B %Y") %></h3>
      <% else %>
        <h3 class="text-success">All Events</h3>
      <% end %>
    </div>
    <% if notice %>
      <div class="alert alert-success col-7 alert-dismissible fade show mx-auto text-center p-2 small" role="alert">
        <%= notice %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="transform: scale(0.7); margin-top: -4px;"></button>
      </div>
    <% end %>
    <% if alert %>
      <div class="alert alert-success col-7 alert-dismissible fade show mx-auto text-center p-2 small" role="alert">
        <%= alert %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="transform: scale(0.7); margin-top: -4px;"></button>
      </div>
    <% end %>

    <div class="d-flex justify-content-between mb-3">
      <%= link_to "Back to Calendar", calendar_index_path, class: "btn btn-sm btn-success" %>
    </div>

    <% if @events.present? %>
      <ul class="list-group mt-3">
        <% @events.each do |event| %>
          <li class="list-group-item border-0 rounded shadow-sm mb-3">
            <div class="d-flex justify-content-between">
              <div>
                <strong><%= event.summary %></strong>
                <% if event.start.date_time %>
                  <br>
                  <small>
                    <span class="badge bg-warning text-light">Timed</span>
                    <%= event.start.date_time.strftime("%B %d, %Y at %I:%M %p") %>
                    <% if event.end.date_time %>
                      - <%= event.end.date_time.strftime("%B %d, %Y at %I:%M %p") %>
                    <% end %>
                  </small>
                <% elsif event.start.date %>
                  <br>
                  <small>
                    <span class="badge bg-success">All Day</span>
                    <%= Date.parse(event.start.date).strftime("%B %d, %Y") %>
                  </small>
                <% end %>
                <div class="mt-3">
                  <% if event.description.present? %>
                    <p><strong>Description:</strong> <%= event.description %></p>
                  <% end %>
      
                  <% if event.location.present? %>
                    <p><strong>Location:</strong> <%= event.location %></p>
                  <% end %>
      
                  <% if event.attendees.present? %>
                    <p><strong>Attendees:</strong></p>
                    <ul>
                      <% event.attendees.each do |attendee| %>
                        <li><%= attendee.email %></li>
                      <% end %>
                    </ul>
                  <% end %>
      
                  <% if event.attachments.present? %>
                    <p><strong>Attachments:</strong></p>
                    <ul>
                      <% event.attachments.each do |attachment| %>
                        <li>
                          <a href="<%= attachment.file_url %>" target="_blank"><%= attachment.title %></a>
                        </li>
                      <% end %>
                    </ul>

                  <% end %>
                </div>
              </div>
              <div class="d-flex ">
                <div class="me-1">
                  <%= link_to "Edit", edit_event_form_calendar_index_path(event_id: event.id) , class: "btn btn-sm btn-success" %>
                </div>
                <div>
                  <%= form_with url: delete_event_calendar_index_path, method: :post, local: true do |form| %>
                    <%= hidden_field_tag :event_id, event.id %>
                    <%= form.submit "Delete", class: "btn btn-sm btn-danger", data: { confirm: "Are you sure?" } %>
                  <% end %>
                </div>
              </div>
            </div>

          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-center mt-4">No events found.</p>
    <% end %>
  </div>
</div>

<style>
  .container {
    background-color: rgba(255, 255, 0, 0.292);
    border-radius: 15px;
  }
  .alert {
    max-width: 500px;
    font-size: 0.9rem;
  }
  .alert .btn-close {
    transform: scale(0.7);
    margin-top: -4px;
  }
  .text-center h3 {
    color: #28a745;
    font-weight: 500;
  }
  .list-group-item {
    background-color: #fff;
    border: 1px solid #ddd;
    border-radius: 10px;
    padding: 15px;
  }
  .list-group-item strong {
    font-size: 1.2rem;
  }
  .badge {
    font-size: 0.8rem;
    padding: 0.3rem 0.6rem;
  }
  .mt-3 {
    margin-top: 1rem;
  }
  .list-group-item p {
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .list-group-item ul {
    list-style-type: none;
    padding-left: 20px;
  }
  .list-group-item li {
    font-size: 0.9rem;
    color: #555;
  }
  .btn-success {
    font-size: 0.9rem;
    padding: 5px 15px;
  }
  @media (max-width: 768px) {
    .alert {
      max-width: 100%;
    }
    .list-group-item {
      padding: 10px;
    }
    .list-group-item strong {
      font-size: 1rem;
    }
    .list-group-item p,
    .list-group-item ul li {
      font-size: 0.8rem;
    }
  }
</style>
