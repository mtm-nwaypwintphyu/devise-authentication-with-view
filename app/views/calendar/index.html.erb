
<%= render 'layouts/navbar' %>
<div class="container-fluid  p-5 rounded" style="height:700px; background-color: rgba(255, 255, 0, 0.292);">
  <% if notice %>
    <div class="alert alert-warning alert-dismissible fade show mx-auto text-center p-3 small col-8 " style=" font-size: 0.9rem;" role="alert">
      <%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="transform: scale(0.7); margin-top: -4px;"></button>
    </div>
  <% end %>
  <div class="text-center mb-4">
    <h3 class="text-success">Calendar</h3>
  </div>
  <div class="calendar-container col-8 m-auto mb-4">
    <%= link_to "Back", root_path, class: "btn btn-sm btn-success my-3" %>
    <table class="calendar w-100">
      <thead>
        <tr>
          <div class="d-flex w-100 justify-content-between">
            <div>
              <h4 class="text-success">
                <%= @first_day.strftime("%Y %B") %>
              </h4>
            </div>  
            <div class="d-flex justify-content-start align-items-center mb-3">
              <%= link_to calendar_index_path(date: @first_day.prev_month.beginning_of_month.to_date), class: 'mx-3 text-success' do %>
                <i class="fas fa-chevron-left"></i>
              <% end %>

              <%= link_to calendar_index_path(date: @first_day.next_month.beginning_of_month.to_date), class: 'mx-3 text-success' do %>
                <i class="fas fa-chevron-right"></i>
              <% end %>

              <div class="mx-2">
                <%= form_tag(calendar_index_path, method: :get, class: 'd-flex align-items-center') do %>
                 <div class="d-flex">
                  <%= select_tag 'month',
                    options_for_select((1..12).map { |m| [Date::MONTHNAMES[m], m] }, @first_day.month),
                    onchange: 'this.form.submit();',
                    class: 'form-select form-select-sm' %>
              
                  <%= select_tag 'year',
                    options_for_select((Date.today.year - 5..Date.today.year + 5).to_a, @first_day.year),
                    onchange: 'this.form.submit();',
                    class: 'form-select form-select-sm mx-2' %>
                 </div>
                <% end %>
              </div>
            </div>
          </div>
        </tr>
        <tr >
          <% Date::ABBR_DAYNAMES.each do |day| %>
            <th class="bg-success text-light" ><%= day %></th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% start_date = @first_day.beginning_of_week(:sunday) %>
        <% end_date = @last_day.end_of_week(:sunday) %>

        <% (start_date..end_date).to_a.in_groups_of(7) do |week| %>
          <tr>
            <% week.each do |date| %>
              <td class="<%= 'today' if date == @today %> <%= 'other-month' if date.month != @first_day.month %>">
                <div class="day-number"><%= date.day %></div>
                <% if @events_by_day[date] %>
                  <ul class="events">
                    <% @events_by_day[date].each do |event| %>
                      <li class="event">
                        <span class="event-time"><%= event.start.date_time.strftime("%I:%M %p") if event.start.date_time %><%= event.summary %></span>
                      </li>
                    <% end %>
                  </ul>
                <% end %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>

    <div class="d-flex justify-content-center mt-3">
      <%= link_to 'View All Events', all_events_path, class: 'btn btn-success btn-sm mb-3 mx-2' %>
      <%= link_to "View Events of #{@first_day.strftime("%Y %B")}", all_events_path(date: Date.today, month_only: true), class: 'btn btn-success btn-sm mb-3 mx-2' %>
      <%= link_to 'View All Holidays', all_holidays_path, class: 'btn btn-success btn-sm mb-3 mx-2' %>
      <%= link_to "View Holidays of #{@first_day.strftime("%Y %B")}", all_holidays_path(date: Date.today, month_only: true), class: 'btn btn-success btn-sm mb-3 mx-2' %>
      <%= link_to 'Create events', create_event_form_calendar_index_path, class: 'btn btn-success btn-sm mb-3 mx-2' %>
    </div>

  </div>
</div>

<style>
  .calendar-container {
    margin-top: 10px;
  }

  table.calendar {
    border-collapse: collapse;
    width: 100%;
    background-color: #fff;
    border-radius: 6px;
    font-size: 12px;
  }

  table.calendar th {
    background-color: #f8f9fa;
    padding: 6px;
    text-align: center;
    font-weight: 600;
    font-size: 12px;
    color: #444;
  }

  table.calendar td {
    width: 14.28%;
    padding: 4px;
    text-align: center;
    vertical-align: top;
    height: 60px;
    border: 1px solid #ddd;
  }

  .today {
    background-color: #e6f7ff;
    font-weight: bold;
  }

  .other-month {
    background-color: #f9f9f9;
    color: #aaa;
  }

  .day-number {
    font-size: 12px;
    font-weight: 600;
  }

  ul.events {
    margin: 2px 0 0;
    padding-left: 10px;
    list-style: none;
  }

  .event {
    background-color: #f1f3f4;
    border-radius: 3px;
    padding: 2px 4px;
    margin-top: 2px;
    font-size: 10px;
  }

  .event-time {
    font-size: 10px;
    color: #555;
  }

  .event:hover {
    background-color: #d0e7ff;
    cursor: pointer;
  }
</style>

