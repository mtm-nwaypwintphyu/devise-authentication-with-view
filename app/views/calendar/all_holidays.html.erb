<%= render 'layouts/navbar' %>
<div class="container-fluid  p-5 rounded" style="background-color: rgba(255, 255, 0, 0.292);">
 <div class="col-10 m-auto">
  <div class="text-center mb-4">
    <% if params[:date].present? && params[:month_only] %>
      <h3 class="text-success">Holidays of <%= @first_day.strftime("%B %Y") %></h3>
    <% else %>
      <h3 class="text-success">All Holidays</h3>
    <% end %>
  </div>

    <div class="d-flex justify-content-between mb-3">
      <%= link_to "Back to Calendar", calendar_index_path, class: "btn btn-sm btn-success" %>
    </div>

    <% if @events_by_day.present? %>
    <table class="table table-bordered table-striped bg-white">
      <thead class="table-success text-center">
        <tr>
          <th>No.</th>
          <th style="width: 30%;">Date</th>
          <th>Holiday Event(s)</th>
        </tr>
      </thead>
      <tbody>
        <% @events_by_day.sort.each_with_index do |(date, events), index| %>
          <tr>
            <td><%= index + 1 %></td>
            <td><strong><%= date.strftime("%B %d, %Y") %></strong></td>
            <td>
              <ul class="mb-0 ps-3">
                <% events.each do |event| %>
                  <li><%= event.summary %></li>
                <% end %>
              </ul>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% else %>
    <p class="text-center">No holidays found.</p>
    <% end %>
  </div>
</div>
