<div class="container form-box col-4 px-5 pt-3 pb-5 mt-3 rounded" style="background-color: rgba(255, 255, 0, 0.292);">
  <h2 class="text-center text-success mb-5">Forgot password?</h2>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
    <div class="form-group mb-4">
      <%= f.label :email, class: "font-weight-bold" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "Enter your email" %>
    </div>

    <div class="form-group my-4 text-center">
      <%= f.submit "Send reset password instructions", class: "btn text-light btn-block w-100 bg-success" %>
    </div>
    <div class=" d-flex justify-content-end">
      <%= link_to "Login", user_session_path, class: "" %>
    </div>
  <% end %>
</div>
