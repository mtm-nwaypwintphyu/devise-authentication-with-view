<div class="col-6 m-auto bg-light p-5 rounded">
  <%= form_with model: @post, local: true do |form| %>
    <div class="form-group mb-4">
      <%= form.label :title, "Title", class: "font-weight-bold" %>
      <%= form.text_field :title, class: "form-control", placeholder: "Enter title" %>
      <% if @post.errors[:title].any? %>
        <div class="text-danger mt-1">
          <%= @post.errors[:title].join(", ") %>
        </div>
      <% end %>
    </div>

    <div class="form-group mb-4">
      <%= form.label :content, "Content", class: "font-weight-bold" %>
      <%= form.text_area :content, class: "form-control", placeholder: "Enter content", rows: 5 %>
      <% if @post.errors[:content].any? %>
        <div class="text-danger mt-1">
          <%= @post.errors[:content].join(", ") %>
        </div>
      <% end %>
    </div>

    <div class="form-group text-center mt-4 mb-2 d-flex justify-content-end col-12">
      <%= form.submit "Update Post", class: "btn text-light btn-block col-2 bg-success" %>
    </div>
  <% end %>
</div>
