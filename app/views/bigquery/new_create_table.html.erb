<%= render 'layouts/navbar' %>

<div class="container col-6">
  <h2 class="text-center my-4">Create BigQuery Table</h2>

  <%= link_to "Back", bigquery_path, class: "btn btn-sm btn-success mb-3" %>

  <% if flash[:alert] %>
    <div class="alert alert-danger alert-dismissible fade show text-center small p-2" role="alert">
      <%= flash[:alert] %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="transform: scale(0.7); margin-top: -4px;"></button>
    </div>
  <% end %>

  <%= form_with url: bigquery_create_table_path(project_id: @project_id, dataset_id: @dataset_id), method: :post, local: true do |f| %>
    <div class="mb-3">
      <%= f.label :table_id, "Table ID", class: "form-label" %>
      <%= f.text_field :table_id, class: "form-control" %>
    </div>

    <h5>Schema Fields</h5>
    <div id="schema-fields">
      <div class="row mb-2 schema-field">
        <div class="col-5">
          <input type="text" name="schema_fields[][name]" class="form-control" placeholder="Field Name">
        </div>
        <div class="col-5">
          <select name="schema_fields[][type]" class="form-select">
           <% BIGQUERY_SUPPORTED_TYPES.each do |type| %>
              <option value="<%= type %>"><%= type %></option>
           <% end %>
          </select>
        </div>
        <div class="col-2">
          <button type="button" class="btn btn-danger btn-sm remove-field">Remove</button>
        </div>
      </div>
    </div>

    <button type="button" id="add-field" class="btn btn-outline-primary btn-sm mb-3">Add Field</button>

    <div class="text-end">
      <%= f.submit "Create Table", class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const addButton = document.getElementById('add-field');
    const fieldWrapper = document.getElementById('schema-fields');

    addButton.addEventListener('click', function() {
      const fieldHTML = `
        <div class="row mb-2 schema-field">
          <div class="col-5">
            <input type="text" name="schema_fields[][name]" class="form-control" placeholder="Field Name">
          </div>
          <div class="col-5">
            <select name="schema_fields[][type]" class="form-select">
              <% BIGQUERY_SUPPORTED_TYPES.each do |type| %>
                <option value="<%= type %>"><%= type %></option>
              <% end %>
            </select>
          </div>
          <div class="col-2">
            <button type="button" class="btn btn-danger btn-sm remove-field">Remove</button>
          </div>
        </div>
      `;
      fieldWrapper.insertAdjacentHTML('beforeend', fieldHTML);
    });

    fieldWrapper.addEventListener('click', function(event) {
      if (event.target.classList.contains('remove-field')) {
        event.target.closest('.schema-field').remove();
      }
    });
  });
</script>
