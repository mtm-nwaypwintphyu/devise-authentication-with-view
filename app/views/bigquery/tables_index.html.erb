
<%= render 'layouts/navbar' %>

<div class="container">
  <h1 class="text-center my-4">BigQuery Tables</h1>

  <% if flash[:error] %>
    <div class="alert alert-danger col-6 alert-dismissible fade show mx-auto text-center p-2 small" role="alert">
      <%= flash[:error] %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="transform: scale(0.7); margin-top: -4px;"></button>
    </div>
  <% end %>
   <% if flash[:notice] %>
    <div class="alert alert-success col-6 alert-dismissible fade show mx-auto text-center p-2 small" role="alert">
      <%= flash[:notice] %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="transform: scale(0.7); margin-top: -4px;"></button>
    </div>
  <% end %>

  <div class="mb-2">
    <%= link_to "Back to Datasets", bigquery_path , class: "btn btn-sm btn-success me-2" %>
  </div>
  <% if @project_id && @dataset_id%>
    <div class="mb-2 d-flex justify-content-end">
      <div>
        <%= link_to "+ Create table", new_bigquery_create_table_path(@project_id, @dataset_id), class: "btn btn-sm btn-success me-2" %>
        <%= link_to "+ Upload table", bigquery_upload_table_form_path(@project_id, @dataset_id), class: "btn btn-sm btn-success me-2" %>
      </div>
    </div>
  <% end %>

  <% if @tables.present? %>
  <table class="table table-bordered table-striped">
    <tr>
      <th>No.</th>
      <% @tables.first.keys.each do |key| %>
        <th><%= key %></th>
      <% end %>
      <th>Detail</th>
    </tr>
    <% @tables.each_with_index do |table, index| %>
        <tr> 
          <td><%= index + 1 %></td>
          <td><%= table[:table_id]%></td>
          <td><%= table[:dataset_id]%></td>
          <td><%= table[:project_id]%></td>
          <td><%= table[:created_at]%></td>
          <td><%= table[:table_type	]%></td>
          <td><%= table[:expiration_time]%></td>
          <td>
            <%= link_to "Data", bigquery_table_detail_path(project_id: table[:project_id], dataset_id: table[:dataset_id], table_id: table[:table_id]), class: "btn btn-sm col-12 mb-1 btn-secondary" %>
            <br>
            <%= link_to "Schema", bigquery_table_schema_path(project_id: table[:project_id], dataset_id: table[:dataset_id], table_id: table[:table_id]), class: "btn col-12 btn-sm mb-1 btn-success" %>
            <br>
            <%= link_to "Edit", bigquery_table_schema_edit_form_path(project_id: table[:project_id], dataset_id: table[:dataset_id], table_id: table[:table_id]), class: "btn col-12 btn-sm mb-1 btn-info" %>
            <br>
            <%= form_with url: bigquery_delete_table_path(table[:project_id], table[:dataset_id], table[:table_id]), method: :post, class: "d-inline" do %>
              <%= submit_tag "Delete", class: "btn col-12 btn-sm mb-1 btn-danger", data: { confirm: "Are you sure you want to delete this table?" } %>
            <% end %>
          </td>
        </tr>
    <% end %>
  </table>
  <% elsif !@error_flg %>
    <p>There is no table in this dataset.</p>
  <% end %>
</div>