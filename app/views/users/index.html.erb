<div class="container col-7 mt-5 p-3 rounded" style="background-color: rgba(255, 255, 0, 0.292);">
  <% if notice %>
    <div class="alert alert-success alert-dismissible fade show mx-auto text-center p-2 small" style="max-width: 500px; font-size: 0.9rem;" role="alert">
      <%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="transform: scale(0.7); margin-top: -4px;"></button>
    </div>
  <% end %>
  <h2 class="mb-4 text-success text-center">Users List</h2>
    <%= link_to "Back", root_path, class: "btn btn-sm btn-secondary" %>
  <div class="col-10 rounded m-auto">
    <table class="table table-bordered table-hover text-center">
      <thead class="table-success">
        <tr>
          <th>Name</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr>
            <td><%= user.full_name %></td>
            <td><%= link_to "Detail", user_path(user), class: "btn btn-sm btn-outline-success" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
