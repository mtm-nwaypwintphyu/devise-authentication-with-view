<div class="col-6 m-auto bg-light p-5 rounded">
  <%= form_with model: user, url: user_path(user), method: :patch, local: true do |form| %>
    <div class="form-group mb-4">
      <%= form.label :first_name, "First Name", class: "font-weight-bold" %>
      <%= form.text_field :first_name, class: "form-control", placeholder: "Enter first name" %>
      <% if @user.errors[:first_name].any? %>
        <div class="text-danger mt-1">
          <%= @user.errors[:first_name].join(", ") %>
        </div>
      <% end %>
    </div>

    <div class="form-group mb-4">
      <%= form.label :last_name, "Last Name", class: "font-weight-bold" %>
      <%= form.text_field :last_name, class: "form-control", placeholder: "Enter last name" %>
      <% if @user.errors[:last_name].any? %>
        <div class="text-danger mt-1">
          <%= @user.errors[:last_name].join(", ") %>
        </div>
      <% end %>
    </div>

    <div class="form-group mb-4">
      <%= form.label :email, "Email", class: "font-weight-bold" %>
      <%= form.text_field :email, class: "form-control", placeholder: "Enter email address" %>
      <% if @user.errors[:email].any? %>
        <div class="text-danger mt-1">
          <%= @user.errors[:email].join(", ") %>
        </div>
      <% end %>
    </div>

    <div class="form-group text-center mt-4 mb-2 d-flex justify-content-end col-12">
      <%= form.submit "Update User", class: "btn text-light btn-block col-2 bg-success" %>
    </div>
  <% end %>
</div>
